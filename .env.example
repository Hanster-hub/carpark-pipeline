# Copy this to .env and fill in your own values. Never commit the real .env.

# Register free at https://datamall.lta.gov.sg/ to get your AccountKey, then paste it here:
LTA_ACCOUNT_KEY=your_key_here

# Kafka
KAFKA_BOOTSTRAP=kafka:9092
TOPIC_CARPARK_RAW=carpark_raw
TOPIC_WEATHER_RAW=weather_raw

# Postgres (dev defaults — change the password for anything real)
PG_HOST=postgres
PG_PORT=5432
PG_DB=carpark
PG_USER=carpark
PG_PASSWORD=carpark

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=carpark_availability
MODEL_NAME=carpark_predictor

# Data lake
LAKE_ROOT=/data/lake

# Weather (Singapore centroid; Open-Meteo needs no key)
WEATHER_LAT=1.3521
WEATHER_LON=103.8198

# Polling
POLL_INTERVAL_SECONDS=60
